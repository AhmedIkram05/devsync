# Flask Application Settings
FLASK_APP=backend/src/app.py
FLASK_ENV=development

# Local PostgreSQL (Docker)
# Start with: docker compose -f docker-compose.local-postgres.yml up -d
DATABASE_URL=postgresql://devsync:devsync@localhost:5432/devsync?sslmode=disable

# Authentication
JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/github/callback
FRONTEND_URL=http://localhost:3000
